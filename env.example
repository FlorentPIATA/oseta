# ============================================================
# OSETA — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer .env dans Git
# ============================================================

# === Base de données ===
DATABASE_URL=postgresql+asyncpg://oseta:oseta@db:5432/oseta
DATABASE_URL_SYNC=postgresql://oseta:oseta@db:5432/oseta

# === Redis ===
REDIS_URL=redis://redis:6379/0
REDIS_TTL_CORRELATION=21600    # 6 heures en secondes
REDIS_TTL_LLM=86400            # 24 heures
REDIS_TTL_SECTORS=43200        # 12 heures

# === LLM — via LiteLLM (choisir 1 provider par défaut) ===
# Provider principal (léger, rapide, économique)
LITELLM_DEFAULT_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...

# Provider premium (analyses complexes, IS > 80)
LITELLM_PREMIUM_MODEL=gpt-4o
LITELLM_PREMIUM_THRESHOLD_IS=80

# Fallback local (optionnel, Ollama)
# LITELLM_FALLBACK_MODEL=ollama/mistral
# OLLAMA_API_BASE=http://localhost:11434

# Provider secondaire
GOOGLE_API_KEY=...

# Budget hard limit quotidien (en USD) — coupe le pipeline si dépassé
LLM_DAILY_BUDGET_USD=50.0

# === APIs données (licites) ===
# FRED — Federal Reserve Economic Data (gratuit)
FRED_API_KEY=...

# EOD Historical Data (légal, ~50€/mois, remplace yfinance)
EODHD_API_KEY=...

# Brave Search API
BRAVE_API_KEY=...

# EventRegistry (actualité structurée)
EVENTREGISTRY_API_KEY=...

# === Recherche web ===
BING_API_KEY=...

# === Auth ===
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 jours

# === Orchestration Prefect ===
PREFECT_API_URL=http://prefect:4200/api

# === App settings ===
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Sécurité ===
# Clé maître pour chiffrement des credentials sources
OSETA_MASTER_KEY=changeme-generate-with-openssl-rand-hex-32

# === Scoring seuils ===
CI_PUBLISH_THRESHOLD=65
IS_ALERT_THRESHOLD=80
CP_ACTION_THRESHOLD=80
